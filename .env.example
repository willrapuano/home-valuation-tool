# ============================================================
# Home Valuation Tool — Required Environment Variables
# ============================================================

# ✅ REQUIRED — Google Maps JavaScript API + Places API
# Get at: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API + Places API (New)
# Restrict to your domain in production
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ⚠️ OPTIONAL BUT RECOMMENDED — Repliers IDX API
# Without this key, the tool uses a fallback price-per-sqft estimate
# Get at: https://app.repliers.io → Settings → API Keys
# Requires BrightMLS-area market access
REPLIERS_API_KEY=your_repliers_api_key_here

# ✅ REQUIRED — GoHighLevel CRM
# Location-level API key (not agency key)
# Get at: GHL Dashboard → Settings → Integrations → API Keys
GHL_API_KEY=your_ghl_api_key_here

# Optional: GHL Location ID for pipeline creation
GHL_LOCATION_ID=your_ghl_location_id_here

# ============================================================
# Agent Branding (update for each client deployment)
# ============================================================
NEXT_PUBLIC_AGENT_NAME=Agent Name
NEXT_PUBLIC_AGENT_EMAIL=agent@brokerage.com
NEXT_PUBLIC_AGENT_PHONE=(555) 555-5555
NEXT_PUBLIC_AGENT_BROKERAGE=Brokerage Name
NEXT_PUBLIC_AGENT_LICENSE=State License Number
